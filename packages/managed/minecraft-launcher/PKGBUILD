# Used to install: https://aur.archlinux.org/minecraft-launcher.git

pkgname=minecraft-launcher
pkgdesc='Official Minecraft Launcher'
epoch=1
pkgver=2.1.3
pkgrel=1
url='https://www.minecraft.net'
arch=('x86_64')
depends=(
    'curl'
    'gtk3'
    'libstdc++'
)
options=(
    '!strip'
    '!debug'
)
source=(
    'Minecraft.deb::https://launcher.mojang.com/download/Minecraft.deb'
    'minecraft-launcher.sh'
)
sha256sums=(
    'de839e5221b215b2c9d39ec9d9dcac9b143ed43e994e1160a31f7f81c91be9ee'
    'cb5f834087724c7c973bb9698141651ca114329fc35e8cd0586ca9404b8dd65f'
)
license=(
    'custom'
)

package() {
    bsdtar -xf 'data.tar.xz' -C "${pkgdir}/"

    # Ship our own wrapper that works around a CEF cache bug (see the script
    # itself for the upstream/KDE bug reports): a stale CEF_VERSION file left
    # behind in ~/.minecraft can leave the launcher unable to start, so we
    # clear it before every launch.
    install -Dm755 'minecraft-launcher.sh' "${pkgdir}/usr/bin/minecraft-launcher.sh"

    # Point the shipped desktop entry at the wrapper instead of the raw binary
    sed -i 's|^Exec=minecraft-launcher$|Exec=minecraft-launcher.sh|' "${pkgdir}/usr/share/applications/minecraft-launcher.desktop"
}
