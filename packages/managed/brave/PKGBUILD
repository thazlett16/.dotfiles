# Used to install: https://aur.archlinux.org/brave-bin.git
# https://github.com/brave/brave-browser/releases/tag/v1.92.139

pkgname=brave
pkgdesc='Brave Browser Stable'
pkgver=1.92.139
pkgrel=1
url='https://brave.com'
arch=('x86_64')
depends=(
    'alsa-lib'
    'ca-certificates'
    'curl'
    'dbus'
    'expat'
    'gtk3'
    'libcups'
    'libxss'
    'libxtst'
    'mesa'
    'nss'
    'ttf-liberation'
    'vulkan-icd-loader'
    'wget'
    'xdg-utils'
)
options=(
    '!emptydirs'
    '!strip'
    '!debug'
)
source=(
    "brave-browser_${pkgver}_amd64.deb::https://github.com/brave/brave-browser/releases/download/v${pkgver}/brave-browser_${pkgver}_amd64.deb"
)
sha256sums=(
    '505415f2206c6ba1dd5211869e0a62df8d68e35c91a1e9e4c5b1b633dd0eeb60'
)
license=(
    'MPL2'
)

package() {
    bsdtar -xf 'data.tar.xz' -C "${pkgdir}/"

    for size in '16' '24' '32' '48' '64' '128' '256'; do
        install -Dm644 "${pkgdir}/opt/brave.com/brave/product_logo_${size}.png" "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/brave-desktop.png"
    done

    # Remove the duplicated Icons now that we copied them
    rm -rf "${pkgdir}/opt/brave.com/brave"/product_logo_*.png

    # Remove CRON
    rm -rf "${pkgdir}/etc/cron.daily"
    rm -rf "${pkgdir}/opt/brave.com/brave/cron"

    # Add Licenses
    install -Dm644 "${pkgdir}/opt/brave.com/brave/LICENSE" "${pkgdir}/usr/share/licenses/brave/LICENSE"
}