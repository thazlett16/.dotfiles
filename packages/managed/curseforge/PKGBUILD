# Used to install: https://aur.archlinux.org/curseforge.git

pkgname=curseforge
pkgdesc='CurseForge desktop client'
pkgver=1.310.1_35445
pkgrel=1
url='https://curseforge.com'
arch=('x86_64')
depends=(
    'alsa-lib'
    'dbus'
    'expat'
    'gcc-libs'
    'gtk3'
    'libnotify'
    'libsecret'
    'libxss'
    'libxtst'
    'mesa'
    'nss'
    'systemd-libs'
    'xdg-utils'
)
options=(
    '!strip'
    '!debug'
)
source=(
    "CurseForge_${pkgver/_/-}_amd64.deb::https://curseforge.overwolf.com/electron/linux/CurseForge_${pkgver/_/-}_amd64.deb"
    'LICENSE'
)
sha256sums=(
    '9ad44cbbccb5008223f6e09fd97f28878d8a4454b4eeec83164f2708a0d289ba'
    '135c7ffeb81f4a7ee95a5879651b679e0d1ef9d13c7aa7c262386ad97b48d62f'
)
license=(
    'LicenseRef-overwolf'
    'MIT'
    'LicenseRef-chromium'
)

package() {
    bsdtar -xf 'data.tar.xz' -C "${pkgdir}/"

    # Add /usr/bin option entry
    install -dm755 "${pkgdir}/usr/bin"
    ln -s "/opt/CurseForge/curseforge" "${pkgdir}/usr/bin/CurseForge"

    # Add Licenses
    install -Dm644 'LICENSE' "${pkgdir}/usr/share/licenses/CurseForge/CURSEFORGE-LICENSE"
    install -Dm644 "${pkgdir}/opt/CurseForge/LICENSE.electron.txt" -t "${pkgdir}/usr/share/licenses/CurseForge"
    install -Dm644 "${pkgdir}/opt/CurseForge/LICENSES.chromium.html" -t "${pkgdir}/usr/share/licenses/CurseForge"
}
