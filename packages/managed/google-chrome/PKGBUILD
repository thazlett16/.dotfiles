# Used to install: https://aur.archlinux.org/google-chrome.git

pkgname=google-chrome
pkgdesc='Google Chrome Browser Stable'
pkgver=150.0.7871.46
pkgrel=1
url='https://www.google.com/chrome'
arch=('x86_64')
depends=(
    'alsa-lib'
    'ca-certificates'
    'curl'
    'dbus'
    'expat'
    'gtk3'
    'libcups'
    'libxss'
    'libxtst'
    'mesa'
    'nss'
    'ttf-liberation'
    'vulkan-icd-loader'
    'wget'
    'xdg-utils'
)
options=(
    '!emptydirs'
    '!strip'
    '!debug'
)
source=(
    "google-chrome-stable_${pkgver}-1_amd64.deb::https://dl.google.com/linux/chrome/deb/pool/main/g/google-chrome-stable/google-chrome-stable_${pkgver}-1_amd64.deb"
    'eula_text.html'
)
sha256sums=(
    '69b40139fb73a021a749f32fcde0853fb1781b6f3a8b3caf173ad8f6747faa7c'
    'e93c01576427cad9099f2cf0df0be70d0a2cc0a3a66c743318b2138aa7c4ed93'
)
license=(
    'LicenseRef-chrome'
    'LicenseRef-widevinecdm'
)

package() {
    bsdtar -xf 'data.tar.xz' -C "${pkgdir}/"

    for size in '16' '24' '32' '48' '64' '128' '256'; do
        install -Dm644 "${pkgdir}/opt/google/chrome/product_logo_${size}.png" "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/google-chrome.png"
    done

    # Remove the duplicated Icons now that we copied them
    rm -rf "${pkgdir}/opt/google/chrome"/product_logo_*.png

    # Remove CRON
    rm -rf "${pkgdir}/etc/cron.daily"
    rm -rf "${pkgdir}/opt/google/chrome/cron"

    # Add Licenses
    install -Dm644 'eula_text.html' "${pkgdir}/usr/share/licenses/google-chrome/eula_text.html"
    install -Dm644 "${pkgdir}/opt/google/chrome/WidevineCdm/LICENSE" "${pkgdir}/usr/share/licenses/google-chrome/WidevineCdm-LICENSE.txt"
}